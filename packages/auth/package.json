{
  "name": "@nan0web/auth",
  "version": "3.0.0",
  "description": "Sovereign Identity and Authorization Protocol for nan•web Matrix",
  "type": "module",
  "main": "src/index.js",
  "types": "types/index.d.ts",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "types": "./types/index.d.ts"
    }
  },
  "files": [
    "src/**/*.js",
    "!src/**/*.test.js",
    "!src/README.md.js",
    "types/**/*.d.ts"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --test \"src/**/*.test.js\"",
    "test:docs": "node --test src/README.md.js",
    "test:all": "npm run test && npm run test:docs && npm run build && npm run knip",
    "knip": "knip --production",
    "audit": "pnpm audit --prod || true",
    "precommit": "npm test",
    "play": "node play/demo.js"
  },
  "author": "nan0web",
  "license": "ISC",
  "dependencies": {
    "@nan0web/core": "workspace:*",
    "@nan0web/db": "workspace:*",
    "@nan0web/types": "workspace:*"
  },
  "devDependencies": {
    "@nan0web/test": "workspace:*",
    "knip": "^5.86.0"
  }
}