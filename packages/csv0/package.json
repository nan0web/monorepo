{
  "name": "@nan0web/csv0",
  "version": "3.0.0",
  "description": "CSV with FrontMatter (nan0/yaml) parser",
  "main": "src/index.js",
  "types": "types/index.d.ts",
  "type": "module",
  "files": [
    "src/**/*.js",
    "!src/**/*.test.js",
    "types/**/*.d.ts"
  ],
  "exports": {
    ".": {
      "import": "./src/index.js",
      "types": "./types/index.d.ts"
    }
  },
  "scripts": {
    "prebuild": "rm -rf types/",
    "build": "tsc",
    "clean": "rm -rf dist/ && rm -rf types/",
    "test": "node --test \"src/**/*.test.js\"",
    "test:all": "npm test && npm run build && npm run knip",
    "knip": "knip --production",
    "release": "nan0release publish"
  },
  "author": "YaRaSLove (ЯRаСлав)",
  "license": "ISC",
  "dependencies": {
    "@nan0web/log": "workspace:*"
  },
  "devDependencies": {
    "@nan0web/release": "workspace:*",
    "@nan0web/types": "workspace:*"
  }
}