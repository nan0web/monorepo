{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": false,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"allowJs": true,
		"checkJs": false,
		"baseUrl": ".",
		"outDir": "dist",
		"declaration": true,
		"emitDeclarationOnly": true,
		"declarationDir": "types"
	},
	"include": [
		"src/**/*.js"
	],
	"exclude": [
		"node_modules",
		"**/*.test.js",
		"**/*.story.js",
		"src/test"
	]
}
