{
  "name": "@nan0web/auth-node",
  "version": "3.0.0",
  "description": "Authorization node.js server for nan0web",
  "main": "src/index.js",
  "type": "module",
  "files": [
    "src/**/*.js",
    "!src/**/*.test.js",
    "!src/README.md.js",
    "!src/play/",
    "!src/test/",
    "bin/auth-server.js",
    "types/**/*.d.ts"
  ],
  "bin": {
    "nan0auth": "bin/auth-server.js"
  },
  "scripts": {
    "test": "node --test --test-force-exit --test-timeout=15000 \"src/**/*.test.js\"",
    "test:all": "npm run test && npm run test:docs && npm run build && npm run knip && npm run audit",
    "play": "node bin/auth-play.js",
    "start": "node bin/auth-server.js",
    "build": "tsc",
    "knip": "knip --production",
    "audit": "pnpm audit --prod --audit-level=moderate || true",
    "clean": "rm -rf .cache/ && rm -rf dist/",
    "clean:modules": "rm -rf node_modules",
    "test:docs": "node --test --test-force-exit --test-timeout=3333 src/README.md.js",
    "release:spec": "node --test \"releases/**/*.spec.js\"",
    "release:verify": "node --test \"src/test/releases/**/*.test.js\" || true",
    "release:close": "nan0test release close",
    "test:coverage": "node --experimental-test-coverage --test-coverage-include=\"src/**/*.js\" --test-coverage-exclude=\"src/**/*.test.js\" --test \"src/**/*.test.js\"",
    "test:coverage:collect": "nan0test coverage",
    "test:status": "nan0test status",
    "precommit": "npm test",
    "prepush": "npm test",
    "prepare": "husky",
    "playground": "node playground/main.js"
  },
  "keywords": [],
  "author": "ЯRаСлав YaRaSLove <support@yaro.page>",
  "license": "ISC",
  "packageManager": "pnpm@10.11.0",
  "dependencies": {
    "@nan0web/auth-core": "workspace:*"
  },
  "devDependencies": {
    "@nan0web/db": "workspace:*",
    "@nan0web/db-fs": "workspace:*",
    "@nan0web/http": "workspace:*",
    "@nan0web/http-node": "workspace:*",
    "@nan0web/log": "workspace:*",
    "@nan0web/test": "workspace:*",
    "husky": "^9.1.7",
    "knip": "^5.86.0"
  },
  "peerDependencies": {
    "@nan0web/db": "workspace:*",
    "@nan0web/db-fs": "workspace:*",
    "@nan0web/http": "workspace:*",
    "@nan0web/log": "workspace:*"
  }
}