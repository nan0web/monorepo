{
  "name": "@nan0web/finance",
  "version": "3.0.0",
  "description": "Financial logic, formatting, and calculations for nan0web apps.",
  "type": "module",
  "main": "./src/index.js",
  "types": "./types/index.d.ts",
  "files": [
    "src/**/*.js",
    "!src/**/*.test.js",
    "types/**/*.d.ts"
  ],
  "exports": {
    ".": {
      "import": "./src/index.js",
      "types": "./types/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "knip": "knip --production",
    "test": "node --test --test-timeout=6333 --test-reporter=tap \"src/**/*.test.js\"",
    "test:coverage": "node --experimental-test-coverage --test-coverage-include=\"src/**/*.js\" --test-coverage-exclude=\"src/**/*.test.js\" --test \"src/**/*.test.js\"",
    "test:coverage:collect": "nan0test coverage",
    "test:docs": "node --test --test-timeout=3333 --test-reporter=tap src/README.md.js",
    "test:status": "nan0test status --hide-name --debug",
    "test:all": "npm run test && npm run test:docs && npm run build && npm run knip",
    "precommit": "npm test",
    "prepush": "npm test",
    "release": "nan0release publish",
    "clean": "rm -rf .cache/ && rm -rf dist/",
    "clean:modules": "rm -rf node_modules"
  },
  "keywords": [
    "finance",
    "banking",
    "crypto",
    "calculator",
    "formatting",
    "nan0web"
  ],
  "author": "ЯRаСлав YaRaSLove <support@yaro.page>",
  "license": "ISC",
  "packageManager": "pnpm@10.11.0",
  "devDependencies": {
    "@nan0web/release": "workspace:*",
    "@nan0web/test": "workspace:*",
    "husky": "^9.1.7",
    "knip": "^5.86.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@nan0web/db-browser": "workspace:*"
  }
}