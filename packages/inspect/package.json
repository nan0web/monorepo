{
  "name": "@nan0web/inspect",
  "version": "3.0.0",
  "description": "Engineering inspection and quality control for the NaN0Web ecosystem.",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "nan0inspect": "./bin/inspect.js"
  },
  "exports": {
    ".": {
      "import": "./src/index.js",
      "types": "./src/index.d.ts"
    },
    "./ui/cli": {
      "import": "./src/cli.js",
      "types": "./types/cli.d.ts"
    },
    "./domain/AuditorModel": {
      "import": "./src/domain/AuditorModel.js",
      "types": "./types/domain/AuditorModel.d.ts"
    }
  },
  "scripts": {
    "prebuild": "rm -rf types/",
    "build": "tsc",
    "inspect": "node bin/inspect.js",
    "test": "node --test --test-timeout=10000 src/**/*.test.js",
    "test:all": "npm run test && npm run test:docs && npm run build && npm run knip",
    "test:docs": "node --test --test-timeout=10000 'src/docs/**/*.md.js'",
    "test:coverage": "c8 node --test",
    "play": "nan0cli --data play",
    "release:spec": "node --test releases/**/**/*.spec.js",
    "test:release": "node --test src/test/releases/**/**/*.test.js",
    "knip": "knip --production"
  },
  "dependencies": {
    "@nan0web/icons": "workspace:*",
    "@nan0web/markdown": "workspace:*",
    "@nan0web/core": "workspace:*",
    "@nan0web/types": "workspace:*",
    "@nan0web/ui": "workspace:*",
    "madge": "^8.0.0"
  },
  "devDependencies": {
    "@nan0web/db": "workspace:*",
    "@nan0web/db-fs": "workspace:*",
    "c8": "^11.0.0",
    "knip": "^5.86.0",
    "typescript": "^5.0.0"
  }
}