{
  "name": "@nan0web/co",
  "version": "3.0.0",
  "description": "Communication starts here with a simple Message.",
  "main": "./src/index.js",
  "type": "module",
  "types": "./types/index.d.ts",
  "files": [
    "src/**/*.js",
    "!src/**/*.test.js",
    "types/**/*.d.ts"
  ],
  "exports": {
    ".": {
      "import": "./src/index.js",
      "types": "./types/index.d.ts"
    },
    "./utils": {
      "import": "./src/utils/index.js",
      "types": "./types/utils/index.d.ts"
    }
  },
  "scripts": {
    "prebuild": "rm -rf types",
    "build": "tsc",
    "test": "node --test \"src/**/*.test.js\"",
    "test:coverage": "node --experimental-test-coverage --test-coverage-include=\"src/**/*.js\" --test-coverage-exclude=\"src/**/*.test.js\" --test \"src/**/*.test.js\"",
    "test:coverage:collect": "nan0test coverage",
    "test:docs": "node --test src/README.md.js",
    "test:release": "node --test \"releases/**/*.spec.js\"",
    "test:status": "nan0test status --hide-name --debug",
    "test:play": "node --test play/**/*.test.js",
    "test:all": "npm run test && npm run test:docs && npm run test:play && npm run build",
    "test:all1": "npm run test && npm run test:docs && npm run test:play && npm run test:status && npm run test:play",
    "play": "node play/main.js",
    "precommit": "npm test",
    "prepush": "npm test",
    "release": "nan0release publish",
    "clean": "rm -rf .cache/ && rm -rf dist/",
    "clean:modules": "rm -rf node_modules"
  },
  "keywords": [
    "communication",
    "message",
    "messaging",
    "nan0web"
  ],
  "author": "ЯRаСлав (YaRaSLove) <support@yaro.page>",
  "license": "ISC",
  "packageManager": "pnpm@10.11.0",
  "devDependencies": {
    "@nan0web/log": "workspace:*",
    "@nan0web/release": "workspace:*",
    "@nan0web/test": "workspace:*",
    "@nan0web/ui-cli": "workspace:*",
    "husky": "^9.1.7"
  },
  "dependencies": {
    "@nan0web/db-browser": "workspace:*",
    "@nan0web/event": "workspace:*",
    "@nan0web/types": "workspace:*"
  }
}