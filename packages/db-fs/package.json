{
  "name": "@nan0web/db-fs",
  "version": "3.0.0",
  "description": "Database provider for nan•web with node:fs",
  "main": "src/index.js",
  "types": "types/index.d.ts",
  "type": "module",
  "files": [
    "src/**/*.js",
    "!src/**/*.test.js",
    "!src/README.md.js",
    "!src/test.js",
    "types/**/*.d.ts",
    "!types/README.md.d.ts",
    "!types/test.d.ts"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --test \"src/**/*.js\"",
    "test:nan0test": "node --test \"src/**/*.test.js\" | nan0test parse --fail",
    "test:play": "node --test \"play/**/*.test.js\"",
    "knip": "knip --production",
    "audit": "pnpm audit --prod || true",
    "test:all": "npm run test && npm run test:play && npm run test:docs && npm run build && npm run knip && npm run audit",
    "clean": "rm -rf .cache/ && rm -rf dist/",
    "clean:modules": "rm -rf node_modules",
    "test:docs": "node --test src/README.md.js",
    "test:release": "node --test \"releases/**/*.test.js\"",
    "test:coverage": "node --experimental-test-coverage --test-coverage-include=\"src/**/*.js\" --test-coverage-exclude=\"src/**/*.test.js\" --test-coverage-exclude=\"src/**/index.js\" --test \"src/**/*.test.js\"",
    "test:coverage:collect": "nan0test coverage",
    "test:status": "nan0test status --hide-name",
    "precommit": "npm test",
    "prepush": "npm test",
    "play": "node play/main.js",
    "release": "nan0release publish"
  },
  "keywords": [
    "nanoweb",
    "database",
    "fs"
  ],
  "author": "ЯRаСлав YaRaSLove <support@yaro.page>",
  "license": "ISC",
  "packageManager": "pnpm@10.11.0",
  "devDependencies": {
    "@nan0web/db": "workspace:*",
    "@nan0web/event": "workspace:*",
    "@nan0web/release": "workspace:*",
    "@nan0web/test": "workspace:*",
    "@nan0web/types": "workspace:*",
    "@nan0web/ui-cli": "workspace:*",
    "husky": "^9.1.7",
    "knip": "^5.86.0"
  },
  "peerDependencies": {
    "@nan0web/db": "workspace:*",
    "@nan0web/event": "workspace:*",
    "@nan0web/types": "workspace:*"
  },
  "dependencies": {
    "@nan0web/log": "workspace:*",
    "yaml": "^2.8.2"
  }
}