{
  "name": "@nan0web/auth-core",
  "version": "3.0.0",
  "description": "Core auth primitives: User, Role, Membership, AccessControl, Password, Session",
  "main": "src/index.js",
  "types": "types/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "test": "node --test --test-timeout=3333 \"src/**/*.test.js\" | nan0test parse --fail",
    "test:coverage": "node --test --experimental-test-coverage --test-coverage-include=src/**/*.js",
    "test:docs": "node --test src/README.md.js",
    "test:release": "node --test \"releases/**/*.test.js\"",
    "release:spec": "node --test --test-timeout=5000 \"releases/**/*.spec.js\"",
    "test:coverage:collect": "nan0test coverage",
    "test:status": "nan0test status",
    "precommit": "npm test",
    "prepush": "npm test",
    "clean": "rm -rf .cache/ && rm -rf dist/",
    "clean:modules": "rm -rf node_modules",
    "play": "node play/main.js",
    "test:all": "npm run test && npm run test:docs && npm run build && npm run knip && npm run audit",
    "check": "npm run test:all",
    "knip": "knip --production",
    "audit": "pnpm audit --prod || true"
  },
  "keywords": [],
  "author": "ЯRаСлав YaRaSlove <support@yaro.page>",
  "license": "ISC",
  "packageManager": "pnpm@10.11.0",
  "devDependencies": {
    "@nan0web/test": "workspace:*",
    "@nan0web/types": "workspace:*",
    "husky": "^9.1.7",
    "knip": "^5.86.0"
  },
  "peerDependencies": {
    "@nan0web/types": "workspace:*"
  },
  "dependencies": {
    "@nan0web/db-browser": "workspace:*",
    "@nan0web/log": "workspace:*"
  }
}