{
  "name": "@nan0web/auth.app",
  "version": "3.0.0",
  "description": "Authorization application for nan0web",
  "main": "./src/index.js",
  "type": "module",
  "types": "./types/index.d.ts",
  "files": [
    "src/**/*.js",
    "!src/**/*.test.js",
    "types/**/*.d.ts"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --test --test-timeout=3000 \"src/**/*.test.js\"",
    "test:all": "npm run test && npm run test:docs && npm run build && npm run knip && npm run audit",
    "test:coverage": "node --experimental-test-coverage --test-coverage-include=\"src/**/*.js\" --test-coverage-exclude=\"src/**/*.test.js\" --test \"src/**/*.test.js\"",
    "test:coverage:collect": "nan0test coverage",
    "test:docs": "node --test src/README.md.js",
    "test:release": "node --test \"releases/**/*.test.js\"",
    "test:status": "nan0test status --hide-name --debug",
    "knip": "knip --production",
    "audit": "pnpm audit --prod || true",
    "play": "node play/main.js",
    "cli": "node src/ui-cli/main.js",
    "api": "node src/ui-api/main.js",
    "precommit": "npm test",
    "prepush": "npm test",
    "release": "nan0release publish",
    "clean": "rm -rf .cache/ && rm -rf dist/",
    "clean:modules": "rm -rf node_modules"
  },
  "devDependencies": {
    "@nan0web/auth-core": "workspace:*",
    "@nan0web/auth-node": "workspace:*",
    "@nan0web/http-node": "workspace:*",
    "@nan0web/types": "workspace:*",
    "@nan0web/ui": "workspace:*",
    "@nan0web/ui-cli": "workspace:*",
    "knip": "^5.86.0"
  },
  "peerDependencies": {
    "@nan0web/types": "workspace:*",
    "@nan0web/http-node": "workspace:*",
    "@nan0web/ui": "workspace:*",
    "@nan0web/ui-cli": "workspace:*"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.11.0",
  "dependencies": {
    "@nan0web/log": "workspace:*"
  }
}
